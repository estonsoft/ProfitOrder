<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ProfitOrder.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:ProfitOrder.Controls"
    xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    xmlns:fftransformations="clr-namespace:FFImageLoading.Transformations;assembly=FFImageLoading.Maui"
    xmlns:syncfusion="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:vm="clr-namespace:ProfitOrder.ViewModels"
    Title="Profit Order"
    BackgroundColor="White"
    NavigationPage.HasNavigationBar="False">

    <NavigationPage.TitleView>
        <StackLayout
            Orientation="Horizontal"
            Spacing="10"
            VerticalOptions="Center">

            <Label
                Padding="10,0,0,0"
                FontSize="16"
                Text="Profit Order"
                TextColor="White"
                VerticalTextAlignment="Center" />
        </StackLayout>
    </NavigationPage.TitleView>

    <ContentPage.BindingContext>
        <vm:HomeViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="BannerBackground">White</Color>
            <Color x:Key="Accent">Blue</Color>
            <Color x:Key="AccentOld">#96d1ff</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Shell.SearchHandler>
        <controls:MySearchHandler
            x:Name="SearchBox"
            DisplayMemberName="Name"
            Placeholder="Search Products"
            ShowsResults="false" />
    </Shell.SearchHandler>

    <Grid Margin="{OnPlatform iOS='0,50,0,0', Android='0'}" SafeAreaEdges="{OnPlatform iOS='None', Android='All'}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackLayout Grid.Row="0">
            <Grid
                Margin="0,5,0,0"
                BackgroundColor="White"
                HeightRequest="60"
                HorizontalOptions="Fill"
                VerticalOptions="Center">
                <ffimageloading:CachedImage
                    Margin="20,0,0,0"
                    BackgroundColor="White"
                    HorizontalOptions="Start"
                    Source="menu_blue.png"
                    WidthRequest="30">
                    <ffimageloading:CachedImage.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped" />
                    </ffimageloading:CachedImage.GestureRecognizers>
                </ffimageloading:CachedImage>
                <Entry
                    x:Name="SearchText"
                    Margin="60,10,60,0"
                    ClearButtonVisibility="WhileEditing"
                    Completed="OnSearchTapped"
                    FontSize="14"
                    HorizontalOptions="Fill"
                    Placeholder="Search Products"
                    PlaceholderColor="Gray"
                    TextChanged="Search_TextChanged" />
                <Label
                    Margin="0,5,30,0"
                    BackgroundColor="White"
                    FontFamily="FontAwesomeFreeSolid"
                    FontSize="14"
                    HorizontalOptions="End"
                    Text="&#xF002;"
                    TextColor="RoyalBlue"
                    VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSearchTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
            <BoxView
                BackgroundColor="gray"
                HeightRequest="3"
                HorizontalOptions="Fill"
                VerticalOptions="Fill"
                Color="lightgray" />
        </StackLayout>

        <VerticalStackLayout
            Grid.Row="1"
            HorizontalOptions="Fill"
            VerticalOptions="Start">
            <VerticalStackLayout
                x:Name="lblLoginInfo"
                Margin="0,20,0,0"
                HeightRequest="50"
                HorizontalOptions="Center"
                VerticalOptions="Center">
                <Label
                    x:Name="lblWelcome"
                    Margin="0,0,0,0"
                    FontSize="14"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Text="Welcome"
                    TextColor="black"
                    WidthRequest="500" />
                <Label
                    x:Name="lblUserName"
                    Margin="0,-5,0,0"
                    FontAttributes="Bold"
                    FontSize="14"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Text="Company Name"
                    TextColor="black"
                    WidthRequest="500" />
            </VerticalStackLayout>
            <Border
                Padding="0,0,0,0"
                BackgroundColor="Green"
                Stroke="transparent">
                <Grid
                    BackgroundColor="white"
                    HeightRequest="150"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill">
                    <ffimageloading:CachedImage
                        x:Name="BannerImage"
                        Margin="0,0,0,0"
                        Aspect="Fill"
                        BackgroundColor="white"
                        HeightRequest="150"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                </Grid>
            </Border>
            <Border
                Margin="0,5,0,5"
                Padding="0"
                BackgroundColor="LightGray"
                HeightRequest="48"
                HorizontalOptions="Center"
                Stroke="White"
                VerticalOptions="Start">
                <Border.StrokeShape>
                    <!--  Replaces CornerRadius="10"  -->
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <HorizontalStackLayout
                    Margin="0,10,0,10"
                    Padding="0,0,0,0"
                    HeightRequest="60"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <HorizontalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPastPurchases" />
                    </HorizontalStackLayout.GestureRecognizers>
                    <Label
                        Padding="15,10,0,0"
                        FontAttributes="Bold"
                        FontFamily="FontAwesomeFreeSolid"
                        FontSize="18"
                        HeightRequest="45"
                        HorizontalOptions="Center"
                        Text="&#xF571;"
                        TextColor="blue"
                        VerticalOptions="Center"
                        WidthRequest="45" />
                    <VerticalStackLayout>
                        <Label
                            Margin="0,10,0,0"
                            Padding="0,0,15,0"
                            FontSize="16"
                            HorizontalOptions="Start"
                            Text="Past Purchases"
                            TextColor="Blue" />
                        <HorizontalStackLayout HeightRequest="40">
                            <Label
                                FontSize="12"
                                Text="Reorder"
                                TextColor="blue" />
                            <Label
                                Margin="10,2,0,0"
                                FontAttributes="Bold"
                                FontFamily="FontAwesomeFreeSolid"
                                FontSize="11"
                                Text="&#xF061;"
                                TextColor="blue" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>
            <Grid
                Padding="27,15,0,0"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
                <Label
                    Margin="0,0,0,0"
                    FontAttributes="Bold"
                    FontSize="22"
                    HorizontalOptions="Start"
                    Text="Start Your Cart"
                    TextColor="black"
                    VerticalOptions="Center"
                    WidthRequest="255" />
                <HorizontalStackLayout HorizontalOptions="End">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        HorizontalOptions="Fill"
                        Text="Shop All Items"
                        TextColor="blue"
                        VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnShopNow" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label
                        Margin="20"
                        FontAttributes="Bold"
                        FontFamily="FontAwesomeFreeSolid"
                        FontSize="11"
                        HorizontalOptions="End"
                        Text="&#xF061;"
                        TextColor="blue"
                        VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnShopNow" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewItemsAll" />
                </Grid.GestureRecognizers>
            </Grid>
            <Grid
                Padding="27,5,0,0"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
                <Label
                    Margin="0,0,0,0"
                    FontAttributes="Bold"
                    FontSize="22"
                    HorizontalOptions="Start"
                    Text="Top Categories"
                    TextColor="black"
                    VerticalOptions="Center"
                    WidthRequest="255" />
                <HorizontalStackLayout HorizontalOptions="End">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        HorizontalOptions="Fill"
                        Text="View All"
                        TextColor="blue"
                        VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNewItemsAll" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label
                        Margin="20"
                        FontAttributes="Bold"
                        FontFamily="FontAwesomeFreeSolid"
                        FontSize="11"
                        HorizontalOptions="End"
                        Text="&#xF061;"
                        TextColor="blue"
                        VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNewItemsAll" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewItemsAll" />
                </Grid.GestureRecognizers>
            </Grid>
            <ScrollView>
                <CollectionView
                    x:Name="TopCategoriesCollectionView"
                    Margin="10,0,0,0"
                    HorizontalOptions="Fill"
                    SelectionChanged="TopCategoriesCollectionView_SelectionChanged"
                    SelectionMode="Single"
                    VerticalOptions="Start">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            HorizontalItemSpacing="20"
                            Orientation="Horizontal"
                            VerticalItemSpacing="20" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <controls:HomePageItems />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>
        </VerticalStackLayout>

        <controls:CustomToolbar Grid.Row="2" VerticalOptions="End" />
    </Grid>
</ContentPage>
