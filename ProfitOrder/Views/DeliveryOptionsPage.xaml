<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TPSMobileApp.Views.DeliveryOptionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:TPSMobileApp.Controls"
    xmlns:input="clr-namespace:Plugin.InputKit.Shared.Controls;assembly=Plugin.InputKit"
    
    Title="Delivery / Pickup Options"
    
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <ContentPage.Content>
        <StackLayout>
            <Label
                Padding="0,25,0,0"
                BackgroundColor="White"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="Delivery / Pickup Options"
                TextColor="black" />
            <Label
                Padding="0,0,0,0"
                BackgroundColor="White"
                FontSize="24"
                HorizontalOptions="Center"
                Text="For"
                TextColor="black" />
            <Label
                Padding="0,0,0,0"
                BackgroundColor="White"
                FontSize="24"
                HorizontalOptions="Center"
                Text="Zip Code 94206"
                TextColor="black" />
            <Button
                Margin="0,40,0,0"
                BackgroundColor="LightGray"
                Command="{Binding OpenRegister}"
                CornerRadius="10"
                HeightRequest="40"
                HorizontalOptions="Center"
                Text="Delivery (Not Available)"
                TextColor="Gray"
                WidthRequest="250" />
            <Button
                Margin="0,20,0,0"
                BackgroundColor="Red"
                CornerRadius="10"
                HeightRequest="40"
                HorizontalOptions="Center"
                Text="Select For Pickup"
                TextColor="White"
                WidthRequest="250" />
            <Button
                Margin="0,20,0,0"
                BackgroundColor="Red"
                CornerRadius="10"
                HeightRequest="40"
                HorizontalOptions="Center"
                Text="Select For Shipping"
                TextColor="White"
                WidthRequest="250" />
        </StackLayout>
    </ContentPage.Content>
</ContentPage>