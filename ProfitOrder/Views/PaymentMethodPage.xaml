<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ProfitOrder.Views.PaymentMethodPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:ProfitOrder.Controls"
    Title="Payment Methods"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <ContentPage.Content>
        <Grid Margin="{OnPlatform iOS='0,50,0,0', Android='0'}" SafeAreaEdges="{OnPlatform iOS='None', Android='All'}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="60" />
            </Grid.RowDefinitions>

            <controls:CustomHeader x:Name="CustomHeader" Grid.Row="0" />
            <StackLayout Grid.Row="1" BackgroundColor="White">
                <ScrollView>
                    <StackLayout Orientation="Vertical" VerticalOptions="Fill">
                        <BoxView
                            BackgroundColor="gray"
                            HeightRequest="3"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            Color="lightgray" />
                        <Button
                            x:Name="AddPaymentMethod"
                            Margin="0,10,0,10"
                            Padding="0"
                            BackgroundColor="RoyalBlue"
                            Clicked="OnAddNewPaymentMethodClicked"
                            CornerRadius="10"
                            FontAttributes="Bold"
                            HeightRequest="40"
                            HorizontalOptions="Center"
                            Text="Add New Payment Method"
                            TextColor="White"
                            WidthRequest="200" />
                        <StackLayout
                            x:Name="PaymentMethodListLayout"
                            Orientation="Vertical"
                            VerticalOptions="Fill">
                            <BoxView
                                BackgroundColor="gray"
                                HeightRequest="3"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                Color="lightgray" />
                            <CollectionView x:Name="PaymentMethodList" SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <StackLayout
                                            Margin="0,0,0,0"
                                            Orientation="Vertical"
                                            Spacing="0"
                                            VerticalOptions="Fill">
                                            <StackLayout
                                                Margin="0,15,0,10"
                                                HorizontalOptions="Fill"
                                                Orientation="Horizontal"
                                                VerticalOptions="Center">
                                                <Label
                                                    Margin="30,0,0,0"
                                                    BackgroundColor="White"
                                                    FontAttributes="Bold"
                                                    FontSize="16"
                                                    HorizontalOptions="Fill"
                                                    Text="{Binding DisplayText}"
                                                    TextColor="Black" />
                                            </StackLayout>
                                            <StackLayout
                                                Margin="0,0,0,15"
                                                HorizontalOptions="Fill"
                                                Orientation="Horizontal"
                                                VerticalOptions="Center">
                                                <controls:PaymentMethodLabel
                                                    Margin="30,0,0,0"
                                                    BackgroundColor="White"
                                                    FontSize="14"
                                                    HorizontalOptions="Fill"
                                                    PaymentMethodId="{Binding PaymentMethodId}"
                                                    Text="Use this payment method"
                                                    TextColor="RoyalBlue"
                                                    TextDecorations="Underline"
                                                    WidthRequest="265" />
                                                <controls:PaymentMethodLabel
                                                    Margin="0,0,0,0"
                                                    BackgroundColor="White"
                                                    FontSize="14"
                                                    HorizontalOptions="Fill"
                                                    IsVisible="{Binding IsEditVisible}"
                                                    PaymentMethodId="{Binding PaymentMethodId}"
                                                    Text="Edit"
                                                    TextColor="RoyalBlue"
                                                    TextDecorations="Underline" />
                                            </StackLayout>
                                            <BoxView
                                                BackgroundColor="gray"
                                                HeightRequest="3"
                                                HorizontalOptions="Fill"
                                                VerticalOptions="Fill"
                                                Color="lightgray" />
                                        </StackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </StackLayout>
                    </StackLayout>
                </ScrollView>
            </StackLayout>
            <controls:CustomToolbar x:Name="CustomToolbar" Grid.Row="2" />
        </Grid>
    </ContentPage.Content>
</ContentPage>