<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TPSMobileApp.Views.PaymentMethodPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:TPSMobileApp.Controls"
    Title="Payment Methods"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="60" />
            </Grid.RowDefinitions>

            <StackLayout Grid.Row="0">
                <Label
                    Padding="0,15,0,0"
                    BackgroundColor="White"
                    FontAttributes="Bold"
                    FontSize="24"
                    HorizontalOptions="Center"
                    Text="Select Payment Method"
                    TextColor="black" />
                <StackLayout Margin="20,10,0,0">
                    <StackLayout Orientation="Horizontal">
                        <RadioButton
                            Margin="5,5,0,0"
                            FontAttributes="Bold"
                            FontSize="14" />
                        <Label
                            Margin="0,2,0,0"
                            FontAttributes="Bold"
                            FontSize="14"
                            IsVisible="{OnPlatform Android=true,
                                                   UWP=false}"
                            Text="Card Ending 6409"
                            VerticalOptions="Center"
                            WidthRequest="160">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTapGestureRecognizerTapped_1" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label
                            Margin="0,10,0,0"
                            BackgroundColor="White"
                            FontSize="12"
                            HorizontalOptions="Start"
                            Text="Remove"
                            TextColor="Red"
                            TextDecorations="Underline" />
                    </StackLayout>
                    <StackLayout Orientation="Horizontal">
                        <RadioButton
                            Margin="5,0,0,0"
                            FontAttributes="Bold"
                            FontSize="14" />
                        <Label
                            Margin="0,2,0,0"
                            FontAttributes="Bold"
                            FontSize="14"
                            IsVisible="{OnPlatform Android=true,
                                                   UWP=false}"
                            Text="Card Ending 5221"
                            VerticalOptions="Center"
                            WidthRequest="160">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTapGestureRecognizerTapped_1" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Label
                            Margin="0,10,0,0"
                            BackgroundColor="White"
                            FontSize="12"
                            HorizontalOptions="Start"
                            Text="Remove"
                            TextColor="Red"
                            TextDecorations="Underline" />
                    </StackLayout>
                </StackLayout>
                <Label
                    Padding="0,15,0,0"
                    BackgroundColor="White"
                    FontAttributes="Bold"
                    FontSize="20"
                    HorizontalOptions="Center"
                    Text="Add New Card"
                    TextColor="black" />
                <Frame
                    Padding="20,2,0,0"
                    BackgroundColor="White"
                    BorderColor="Transparent"
                    WidthRequest="300">
                    <Entry
                        x:Name="CompanyName"
                        Margin="0,0,0,0"
                        FontSize="16"
                        HorizontalOptions="Start"
                        Placeholder="Cardholder Name"
                        VerticalOptions="Center"
                        WidthRequest="300" />
                </Frame>
                <Frame
                    Padding="20,0,0,0"
                    BackgroundColor="White"
                    BorderColor="Transparent"
                    WidthRequest="300">
                    <Entry
                        x:Name="CardNumber"
                        Margin="0,0,0,0"
                        FontSize="16"
                        HorizontalOptions="Start"
                        Placeholder="Card Number"
                        VerticalOptions="Center"
                        WidthRequest="300" />
                </Frame>
                <StackLayout
                    Margin="0,0,0,0"
                    HorizontalOptions="Start"
                    Orientation="Horizontal"
                    Spacing="0"
                    VerticalOptions="Center">
                    <Label
                        Padding="23,0,0,0"
                        BackgroundColor="White"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="Exp Date"
                        TextColor="black"
                        VerticalOptions="Center" />
                    <Entry
                        x:Name="ExpMonth"
                        Margin="20,0,0,0"
                        FontSize="16"
                        Placeholder="MM"
                        VerticalOptions="Center"
                        WidthRequest="40" />
                    <Entry
                        x:Name="ExpYear"
                        Margin="10,0,0,0"
                        FontSize="16"
                        Placeholder="YYYY"
                        VerticalOptions="Center"
                        WidthRequest="60" />
                </StackLayout>
                <StackLayout
                    Margin="0,0,0,0"
                    HorizontalOptions="Start"
                    Orientation="Horizontal"
                    Spacing="0"
                    VerticalOptions="Center">
                    <CheckBox Margin="19,0,0,0" VerticalOptions="Center" />
                    <Label
                        Text="Save for future use"
                        TextColor="black"
                        VerticalOptions="Center" />
                </StackLayout>
                <Button
                    Margin="0,10,0,0"
                    Padding="0"
                    BackgroundColor="Red"
                    CornerRadius="10"
                    HeightRequest="40"
                    HorizontalOptions="Center"
                    Text="Save Card"
                    TextColor="White"
                    WidthRequest="200" />
                <StackLayout
                    Margin="0,20,0,0"
                    HorizontalOptions="Start"
                    Orientation="Horizontal"
                    Spacing="0"
                    VerticalOptions="Center">
                    <Label
                        Padding="23,0,0,0"
                        BackgroundColor="White"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="Billing Address"
                        TextColor="black"
                        VerticalOptions="Center" />
                    <CheckBox Margin="20,0,0,0" VerticalOptions="Center" />
                    <Label
                        Text="Same as shipping address"
                        TextColor="black"
                        VerticalOptions="Center" />
                </StackLayout>
                <Frame
                    Padding="20,0,0,0"
                    BackgroundColor="White"
                    BorderColor="Transparent"
                    WidthRequest="300">
                    <Entry
                        x:Name="Address1"
                        Margin="0,0,0,0"
                        FontSize="16"
                        HorizontalOptions="Start"
                        Placeholder="Address Line 1"
                        VerticalOptions="Center"
                        WidthRequest="300" />
                </Frame>
                <Frame
                    Padding="20,2,0,0"
                    BackgroundColor="White"
                    BorderColor="Transparent"
                    WidthRequest="300">
                    <Entry
                        x:Name="Address2"
                        Margin="0,0,0,0"
                        FontSize="16"
                        HorizontalOptions="Start"
                        Placeholder="Address Line 2"
                        VerticalOptions="Center"
                        WidthRequest="300" />
                </Frame>
                <Frame
                    Padding="20,2,0,0"
                    BackgroundColor="White"
                    BorderColor="Transparent"
                    WidthRequest="300">
                    <Entry
                        x:Name="City"
                        Margin="0,0,0,0"
                        FontSize="16"
                        HorizontalOptions="Start"
                        Placeholder="City"
                        VerticalOptions="Center"
                        WidthRequest="300" />
                </Frame>
                <StackLayout
                    Margin="0,2,0,0"
                    HorizontalOptions="Start"
                    Orientation="Horizontal"
                    Spacing="0"
                    VerticalOptions="Center">
                    <Entry
                        x:Name="State"
                        Margin="20,2,0,0"
                        FontSize="16"
                        Placeholder="State"
                        VerticalOptions="Center"
                        WidthRequest="60" />
                    <Entry
                        x:Name="Zip"
                        Margin="20,0,0,0"
                        FontSize="16"
                        Placeholder="Zip"
                        VerticalOptions="Center"
                        WidthRequest="120" />
                </StackLayout>
            </StackLayout>
            <controls:CustomToolbar Grid.Row="1" />
        </Grid>
    </ContentPage.Content>
</ContentPage>