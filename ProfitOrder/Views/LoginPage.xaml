<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TPSMobileApp.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:TPSMobileApp.Controls"
    xmlns:d="http://xamarin.com/schemas/2014/forms/design"
    xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    xmlns:fftransformations="clr-namespace:FFImageLoading.Transformations;assembly=FFImageLoading.Maui"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Account Login"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False"
    mc:Ignorable="d">

    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ScrollView Grid.Row="0">
                <StackLayout
                    Padding="0,0,0,0"
                    BackgroundColor="White"
                    VerticalOptions="Start">
                    <Grid
                        Padding="5,5,0,0"
                        BackgroundColor="White"
                        VerticalOptions="Start">
                        <Label
                            x:Name="AppVersion"
                            Padding="0,0,0,0"
                            BackgroundColor="White"
                            FontSize="14"
                            HorizontalOptions="Start"
                            TextColor="black" />
                        <ImageButton
                            Padding="0,0,0,10"
                            Aspect="AspectFit"
                            BackgroundColor="Transparent"
                            Clicked="Settings_Clicked"
                            HeightRequest="50"
                            HorizontalOptions="End"
                            Source="settings.png"
                            WidthRequest="50" />
                    </Grid>
                    <StackLayout
                        Padding="0,20,0,0"
                        BackgroundColor="White"
                        VerticalOptions="Start">
                        <ffimageloading:CachedImage
                            x:Name="Logo"
                            Margin="6"
                            Aspect="AspectFit"
                            HeightRequest="120"
                            HorizontalOptions="Center"
                            Source="logo.png"
                            StyleClass="FlyoutHeaderStyle"
                            VerticalOptions="Center"
                            WidthRequest="300" />
                        <Label
                            Padding="0,10,0,0"
                            BackgroundColor="White"
                            FontAttributes="Bold"
                            FontSize="30"
                            HorizontalOptions="Center"
                            Text="Sign In"
                            TextColor="black" />
                        <Entry
                            x:Name="User"
                            Margin="0,40,0,0"
                            FontSize="18"
                            HeightRequest="40"
                            HorizontalOptions="Center"
                            Placeholder="Username"
                            PlaceholderColor="Gray"
                            Text="{Binding User}"
                            VerticalOptions="Center"
                            WidthRequest="250" />
                        <Entry
                            x:Name="Password"
                            Margin="0,20,0,0"
                            FontSize="18"
                            HeightRequest="40"
                            HorizontalOptions="Center"
                            IsPassword="true"
                            Placeholder="Password"
                            PlaceholderColor="Gray"
                            Text="{Binding Password}"
                            VerticalOptions="Center"
                            WidthRequest="250" />
                        <Grid
                            Padding="0,5,0,0"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="0.25*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox
                                x:Name="RememberMe"
                                Grid.Row="1"
                                Grid.Column="1"
                                IsChecked="{Binding RememberMe}"
                                VerticalOptions="Center"
                                Color="blue" />
                            <Label
                                Grid.Row="1"
                                Grid.Column="2"
                                FontSize="12"
                                Text="Remember Me"
                                TextColor="black"
                                VerticalOptions="Center" />
                        </Grid>
                        <Button
                            Margin="0,20,0,0"
                            Padding="0,0,0,0"
                            BackgroundColor="blue"
                            Command="{Binding LoginCommand}"
                            CornerRadius="10"
                            FontAttributes="Bold"
                            FontSize="14"
                            HeightRequest="35"
                            HorizontalOptions="Center"
                            Text="       Sign In       "
                            TextColor="White"
                            TextTransform="None" />
                        <ActivityIndicator
                            x:Name="WaitImage"
                            HeightRequest="80"
                            HorizontalOptions="Center"
                            IsVisible="{Binding IsLoggingIn}"
                            VerticalOptions="Center" />
                    </StackLayout>
                </StackLayout>
            </ScrollView>
        </Grid>
    </ContentPage.Content>
</ContentPage>