<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ProfitOrder.Views.PurchaseHistoryDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:ProfitOrder.Controls"
    xmlns:local="clr-namespace:ProfitOrder.ViewModels"
    xmlns:syncfusion="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    Title="Monthly Ad"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <NavigationPage.TitleView>
        <StackLayout
            Orientation="Horizontal"
            Spacing="10"
            VerticalOptions="Center">

            <Label
                Padding="10,0,0,0"
                FontSize="16"
                Text="Profit Order"
                TextColor="White"
                VerticalTextAlignment="Center" />
        </StackLayout>
    </NavigationPage.TitleView>

    <!--
    <Shell.SearchHandler>
        <controls:MySearchHandler Placeholder="Search Products" ShowsResults="false" DisplayMemberName="Name" />
    </Shell.SearchHandler>
    -->

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="BannerBackground">White</Color>
            <Color x:Key="Accent">#96d1ff</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Content>
        <Grid Margin="{OnPlatform iOS='0,50,0,0', Android='0'}" SafeAreaEdges="{OnPlatform iOS='None', Android='All'}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <controls:CustomHeader Grid.Row="0" />
            <StackLayout
                Grid.Row="1"
                Margin="0,0,0,0"
                Orientation="Vertical"
                Spacing="0"
                VerticalOptions="Start">
                <BoxView
                    BackgroundColor="gray"
                    HeightRequest="3"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    Color="lightgray" />
                <StackLayout
                    Margin="0,10,0,0"
                    Orientation="Vertical"
                    Spacing="0"
                    VerticalOptions="Start">
                    <StackLayout
                        Margin="0,0,0,0"
                        HorizontalOptions="Start"
                        Orientation="Horizontal"
                        VerticalOptions="Start">
                        <Label
                            Margin="40,0,0,0"
                            BackgroundColor="White"
                            FontSize="16"
                            HorizontalOptions="Start"
                            Text="Order #"
                            TextColor="DimGray" />
                        <Label
                            Margin="5,0,0,0"
                            BackgroundColor="White"
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="Start"
                            Text="{Binding OrderNo}"
                            TextColor="Black"
                            WidthRequest="100" />
                        <Label
                            Margin="50,0,0,0"
                            BackgroundColor="White"
                            FontAttributes="Bold"
                            FontSize="16"
                            HorizontalOptions="Start"
                            Text="{Binding OrderDateDisplay}"
                            TextColor="Black" />
                    </StackLayout>
                    <StackLayout
                        Margin="0,0,0,0"
                        HorizontalOptions="Start"
                        Orientation="Horizontal"
                        VerticalOptions="Start">
                        <Label
                            Margin="40,0,0,0"
                            BackgroundColor="White"
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="Start"
                            Text="{Binding Items}"
                            TextColor="Black"
                            WidthRequest="35" />
                        <Label
                            Margin="5,0,0,0"
                            BackgroundColor="White"
                            FontSize="16"
                            HorizontalOptions="Start"
                            Text="Items"
                            TextColor="DimGray" />
                    </StackLayout>
                    <StackLayout
                        Margin="0,0,0,0"
                        HorizontalOptions="Start"
                        Orientation="Horizontal"
                        VerticalOptions="Start">
                        <Label
                            Margin="40,0,0,0"
                            BackgroundColor="White"
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="Start"
                            Text="{Binding Pieces}"
                            TextColor="Black"
                            WidthRequest="35" />
                        <Label
                            Margin="5,0,0,0"
                            BackgroundColor="White"
                            FontSize="16"
                            HorizontalOptions="Start"
                            Text="Pieces"
                            TextColor="DimGray" />
                    </StackLayout>
                    <Label
                        Margin="40,0,0,10"
                        BackgroundColor="White"
                        FontAttributes="Bold"
                        FontSize="18"
                        HorizontalOptions="Start"
                        Text="{Binding TotalDisplay}"
                        TextColor="Black"
                        WidthRequest="250" />
                    <BoxView
                        BackgroundColor="gray"
                        HeightRequest="3"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        Color="lightgray" />
                </StackLayout>

            </StackLayout>
            <CollectionView
                x:Name="OrderItemsList"
                Grid.Row="2"
                SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <controls:CustomListItem x:Name="CustomListItem" Grid.Row="0" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <controls:CustomToolbar Grid.Row="3" />
        </Grid>
    </ContentPage.Content>
</ContentPage>
