<ContentView
    x:Class="TPSMobileApp.Controls.HomePageItems"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:TPSMobileApp.Controls"
    xmlns:ff="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    xmlns:fftransformations="clr-namespace:FFImageLoading.Transformations;assembly=FFImageLoading.Maui">

    <VerticalStackLayout BackgroundColor="White">
        <ffimageloading:CachedImage
            Aspect="AspectFit"
            ErrorPlaceholder="missing_item.jpg"
            HeightRequest="100"
            LoadingPlaceholder="missing_item.jpg"
            Source="{Binding ImageURL}"
            WidthRequest="100" />
        <Label
            BackgroundColor="White"
            FontAttributes="Bold"
            FontSize="14"
            HorizontalTextAlignment="Center"
            LineBreakMode="WordWrap"
            Text="{Binding Description}"
            TextColor="Blue" />
    </VerticalStackLayout>
</ContentView>
